# Copy this file to .env and fill in your values.
# Generate secrets with: openssl rand -hex 32

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=attendance
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Connection pool tuning (defaults are fine for most deployments)
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_CONNECT_TIMEOUT=5000

# ── Application ───────────────────────────────────────────
# App name — shown in emails and Excel exports
APP_NAME=Vendor Attendance

# Host port the frontend is served on
APP_PORT=80

# JWT signing secret — must be long and random, never reuse across environments
JWT_SECRET=change-me

# Comma-separated list of allowed CORS origins (no trailing slash)
CORS_ORIGIN=https://yourdomain.com

# Set to "production" in prod, "development" locally
NODE_ENV=production

# Force secure (HTTPS-only) cookies; set to false only for local HTTP development
COOKIE_SECURE=true

# Max upload/request body size — used by both nginx and the Express backend
# nginx format: 20m  (megabytes with "m" suffix)
CLIENT_MAX_BODY_SIZE=20m

# HSTS max-age in seconds — set to 31536000 (1 year) once HTTPS is confirmed working
# 0 = disabled (safe default for HTTP / first-time HTTPS setup)
HSTS_MAX_AGE=0

# ── Auth & Security ───────────────────────────────────────
# How long a JWT session lasts (hours)
JWT_EXPIRY_HOURS=8

# bcrypt cost factor — increase for stronger hashing (each +1 doubles hashing time)
BCRYPT_ROUNDS=10

# ── OTP ───────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# Max OTP requests per window
OTP_RATE_LIMIT_MAX=3
# Window in milliseconds (default: 60000 = 1 minute)
OTP_RATE_LIMIT_WINDOW_MS=60000

# ── Login Rate Limiting ───────────────────────────────────
# Max login attempts per window
LOGIN_RATE_LIMIT_MAX=10
# Window in milliseconds (default: 900000 = 15 minutes)
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# ── Backend (local dev without Docker) ────────────────────
# Only needed when running the backend directly (npm run dev)
# PORT=5000
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
